# Copiar este archivo a ".env" (en la raíz del repo) y completar los valores
SECRET_KEY=cambiar-por-una-clave-secreta
DEBUG=True

# Hosts permitidos para el servidor Django (separados por coma).
# '*' permite cualquier host, útil en desarrollo para host.wokwi.internal
# (simulador Wokwi) o la IP local de la PC (ESP32 físico).
ALLOWED_HOSTS=localhost,127.0.0.1,host.wokwi.internal,*

# MySQL
DB_NAME=access_control
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
